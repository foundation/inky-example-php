{
  "name": "foundation/inky-example-php",
  "description": "Examples: Using the Inky email framework from PHP",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "foundation/inky": "*",
    "twig/twig": "^3.0"
  },
  "repositories": [
    { "type": "path", "url": "../inky/bindings/php", "options": { "symlink": true } }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "classmap": ["src/"]
  },
  "scripts": {
    "examples": "php build.php",
    "verify": "php build.php --verify"
  }
}
